    "react-dom": "^19.2.6",
    "react-router-dom": "^6.30.4",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
